# Server Configuration
PORT=5001
NODE_ENV=development
API_VERSION=v1

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Squadco Payment Gateway (SANDBOX MODE - for testing)
SQUADCO_API_KEY=sandbox_sk_your_sandbox_key_here
SQUADCO_PUBLIC_KEY=sandbox_pk_your_sandbox_key_here
SQUADCO_API_URL=https://sandbox-api-d.squadco.com

# For Production, use:
# SQUADCO_API_KEY=sk_your_production_key_here
# SQUADCO_PUBLIC_KEY=pk_your_production_key_here
# SQUADCO_API_URL=https://api.squadco.com
